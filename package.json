{
  "name": "deckli",
  "version": "0.0.1",
  "description": "Download DocSend decks as PDF — one command, full quality",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "deckli": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "docsend",
    "slides",
    "download",
    "pdf",
    "cli"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.3.0",
    "archiver": "^7.0.1",
    "commander": "^12.1.0",
    "dotenv": "^17.3.1",
    "figures": "^6.1.0",
    "openai": "^6.32.0",
    "ora": "^8.1.1",
    "pdf-lib": "^1.17.1",
    "picocolors": "^1.1.0",
    "playwright": "^1.49.0",
    "string-width": "^7.2.0",
    "tesseract.js": "^5.1.0"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "playwright"
    ]
  }
}
